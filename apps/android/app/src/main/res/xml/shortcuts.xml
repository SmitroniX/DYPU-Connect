    <shortcut
        android:shortcutId="messages"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/shortcut_messages"
        android:shortcutLongLabel="@string/shortcut_messages_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.dypu.connect"
            android:targetClass="com.dypu.connect.MainActivity"
            android:data="https://dypu-connect.netlify.app/messages" />
    </shortcut>
