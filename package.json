{
  "name": "dypu-connect-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "npm run dev --workspace=apps/web",
    "web:build": "npm run build --workspace=apps/web",
    "desktop:dev": "npm run start --workspace=apps/desktop",
    "desktop:build": "npm run dist --workspace=apps/desktop",
    "android:build": "cd apps/android && ./gradlew assembleDebug",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build:all": "npm run web:build && npm run desktop:build"
  },
  "devDependencies": {
    "typescript": "^5",
    "eslint": "^9"
  }
}
