rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function participant(chatId) {
      return signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/private_chats/$(chatId)).data.participants;
    }

    function isGroupMember(groupId) {
      return signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if owner(userId)
        && request.resource.data.userId == request.auth.uid
        && (
          request.resource.data.role == "user" ||
          (
            request.auth.token.email == "asm.jog.rt25@dypatil.edu" &&
            request.resource.data.role == "admin"
          )
        )
        && request.resource.data.status == "active";
      allow update: if (
        owner(userId)
        && request.resource.data.userId == resource.data.userId
        && (
          request.resource.data.role == resource.data.role ||
          (
            request.auth.token.email == "asm.jog.rt25@dypatil.edu" &&
            request.resource.data.role == "admin"
          )
        )
        && request.resource.data.status == resource.data.status
      ) || isAdmin();
      allow delete: if isAdmin();

      // ── User activity log (per-user subcollection) ──────
      match /activity_log/{logId} {
        allow read, create: if owner(userId);
      }

      // ── Device sessions (per-user subcollection) ────────
      match /sessions/{sessionId} {
        allow read, create, update: if owner(userId);
        allow delete: if owner(userId) || isAdmin();
      }

      // ── Notifications (per-user subcollection) ──────────
      match /notifications/{notifId} {
        allow read, update, delete: if owner(userId);
        allow create: if signedIn();
      }
    }

    match /public_chat/{docId} {
      allow read, create: if signedIn();
      allow update: if signedIn();       // reactions
      allow delete: if isAdmin();
    }

    match /anonymous_public_chat/{docId} {
      allow read, create: if signedIn();
      allow update: if signedIn();       // reactions
      allow delete: if isAdmin();
    }

    match /confessions_public/{docId} {
      allow read, create, update: if signedIn();
      allow delete: if isAdmin();

      // ── Per-user likes (prevent duplicates) ────────
      match /likes/{likeUserId} {
        allow read: if signedIn();
        allow create, delete: if signedIn() && request.auth.uid == likeUserId;
      }
    }

    // ── Groups (Hierarchical & Custom) ─────────────
    match /groups/{groupId} {
      // Anyone signed in can read the group list (for directory)
      allow read: if signedIn();
      // Only admins or the system can create groups initially
      allow create: if isAdmin();
      // Allow taking membership (adding self to memberIds)
      allow update: if signedIn(); 
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if isGroupMember(groupId) || isAdmin();
        allow create: if isGroupMember(groupId);
        allow update: if isGroupMember(groupId); // reactions
        allow delete: if isAdmin();
      }
    }

    match /private_chats/{chatId} {
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;
      allow read: if (signedIn() && request.auth.uid in resource.data.participants) || isAdmin();
      allow update: if signedIn() && request.auth.uid in resource.data.participants;
      allow delete: if isAdmin();
    }

    match /private_messages/{chatId}/messages/{msgId} {
      allow read: if participant(chatId) || isAdmin();
      allow create: if participant(chatId);
      allow update: if participant(chatId);  // reactions
      allow delete: if isAdmin();
    }

    // ── WebRTC call signaling ─────────────────────────────
    match /calls/{callId} {
      allow read: if signedIn() 
        && (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid);
      allow create: if signedIn();
      allow update, delete: if signedIn()
        && (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid);

      match /callerCandidates/{docId} {
        allow read, write: if signedIn();
      }
      match /calleeCandidates/{docId} {
        allow read, write: if signedIn();
      }
    }

    match /anonymous_public_chat_private/{docId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.messageId == docId;
      allow read, update, delete: if isAdmin();
    }

    match /confessions_private/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Reports (user-submitted content flags) ──────────────
    match /reports/{docId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    // ── Announcements (admin broadcasts to students) ────────
    match /announcements/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /system_settings/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // ── Admin audit log (tracks all admin actions) ──────────
    match /admin_audit_log/{docId} {
      allow create: if isAdmin();
      allow read: if isAdmin();
    }
  }
}
