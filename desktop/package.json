{
  "name": "dypu-connect-desktop",
  "version": "1.0.0",
  "description": "Desktop app for DYPU Connect",
  "repository": "https://github.com/CodeVerseOrg/DYPU-Connect.git",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "author": "CodeVerseOrg",
  "license": "MIT",
  "build": {
    "appId": "com.codeverse.dypuconnect",
    "productName": "DYPU Connect",
    "publish": [
      {
        "provider": "github",
        "owner": "CodeVerseOrg",
        "repo": "DYPU-Connect"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "icon.png",
      "target": "nsis",
      "publisherName": "CodeVerseOrg"
    },
    "protocols": {
      "name": "dypu-connect-protocol",
      "schemes": [
        "dypu-connect"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  }
}
